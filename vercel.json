{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "frontend/dist",
  "rewrites": [
    {
      "source": "/generate",
      "destination": "/api/generate"
    },
    {
      "source": "/upload",
      "destination": "/api/upload"
    },
    {
      "source": "/health",
      "destination": "/api/health"
    }
  ]
}
